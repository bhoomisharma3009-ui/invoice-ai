        "jsCode": "// Error handler — log failures to console and return structured error\nconst items = $input.all();\nconst results = [];\n\nfor (const item of items) {\n  const errorInfo = {\n    timestamp: new Date().toISOString(),\n    error_type: 'PROCESSING_FAILURE',\n    error_message: item.json.error || 'Unknown error occurred',\n    invoice_data: item.json,\n    node: $workflow.name\n  };\n  \n  console.error('Invoice Processing Error:', JSON.stringify(errorInfo));\n  \n  results.push({\n    json: errorInfo\n  });\n}\n\nreturn results;"
      },
