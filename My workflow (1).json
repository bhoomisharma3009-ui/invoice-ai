    {
      "parameters": {
        "jsCode": "// Pass image file directly — no conversion needed\nconst items = $input.all();\nconst results = [];\n\nfor (const item of items) {\n  try {\n    const binaryData = item.binary;\n    const binaryKey = Object.keys(binaryData)[0];\n    const fileData = binaryData[binaryKey];\n    \n    const base64Data = fileData.data;\n    const mimeType = fileData.mimeType || 'image/jpeg';\n    \n    results.push({\n      json: {\n        image_base64: base64Data,\n        mime_type: mimeType,\n        source_type: 'image',\n        filename: fileData.fileName || 'invoice.jpg',\n        page_count: 1\n      },\n      binary: binaryData\n    });\n  } catch (error) {\n    results.push({\n      json: {\n        error: `Image processing failed: ${error.message}`,\n        source_type: 'image'\n      }\n    });\n  }\n}\n\nreturn results;"
      },
